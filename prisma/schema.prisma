generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Car {
  id          Int           @id @default(autoincrement())
  make        String
  model       String
  year        Int
  division    String
  piClass     String
  piRating    Int
  country     String
  source      String
  sourceInfo  String?
  // Fields not in CSV yet — filled in later
  drivetrain  String?
  engineType  String?
  engineCC    Int?
  cylinders   Int?
  bodyStyle   String?

  // Page 1 — bar stats (0–10 scale, sourced from in-game stat screen)
  statSpeed        Float?
  statHandling     Float?
  statAcceleration Float?
  statLaunch       Float?
  statBraking      Float?
  statOffroad      Float?

  // Page 2 — raw specs
  powerHp       Int?
  torqueFtLb    Int?
  weightLb      Int?
  frontWeight   Int?    // weight distribution % — e.g. 40 means 40/60 F/R
  displacementL Float?

  // Identity
  rarity  String?  // Common | Rare | Legendary | Forza Edition

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  garage      UserGarage[]

  @@index([make])
  @@index([division])
  @@index([piClass])
}

model UserGarage {
  id      Int       @id @default(autoincrement())
  carId   Int
  car     Car       @relation(fields: [carId], references: [id])
  addedAt DateTime  @default(now())
  notes   String?
  tags    CarTag[]
}

model CarTag {
  id            Int        @id @default(autoincrement())
  userGarageId  Int
  userGarage    UserGarage @relation(fields: [userGarageId], references: [id])
  tag           String
  source        String     @default("user") // "auto" | "user"
}
