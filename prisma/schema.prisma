generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Car {
  id          Int           @id @default(autoincrement())
  make        String
  model       String
  year        Int
  division    String
  piClass     String
  piRating    Int
  country     String
  source      String
  sourceInfo  String?
  // Fields not in CSV yet — filled in later
  drivetrain  String?
  engineType  String?
  engineCC    Int?
  cylinders   Int?
  bodyStyle   String?

  // Page 1 — bar stats (0–10 scale, sourced from in-game stat screen)
  statSpeed        Float?
  statHandling     Float?
  statAcceleration Float?
  statLaunch       Float?
  statBraking      Float?
  statOffroad      Float?

  // Page 2 — raw specs
  powerHp       Int?
  torqueFtLb    Int?
  weightLb      Int?
  frontWeight   Int?    // weight distribution % — e.g. 40 means 40/60 F/R
  displacementL Float?

  // Identity
  value   Int?     // purchase price in credits
  rarity  String?  // Common | Rare | Legendary | Forza Edition

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  garage       UserGarage[]
  metaEntries  CarMeta[]

  @@unique([year, make, model])
  @@index([make])
  @@index([division])
  @@index([piClass])
}

model UserGarage {
  id        Int      @id @default(autoincrement())
  userId    String
  carId     Int
  car       Car      @relation(fields: [carId], references: [id])
  addedAt   DateTime @default(now())
  notes     String?
  pinned    Boolean  @default(false)
  tags      CarTag[]

  @@index([userId])
  @@unique([userId, carId])
}

model CarMeta {
  id         Int       @id @default(autoincrement())
  carId      Int
  car        Car       @relation(fields: [carId], references: [id], onDelete: Cascade)
  piClass    String
  raceType   String
  rank       Int?
  label      String
  notes      String?
  source     String
  active     Boolean   @default(true)
  recordedAt DateTime  @default(now())
  replacedAt DateTime?

  @@index([carId])
  @@index([piClass])
  @@index([raceType])
  @@index([recordedAt])
  @@index([active, piClass, raceType])
}

model CarTag {
  id            Int        @id @default(autoincrement())
  userGarageId  Int
  userGarage    UserGarage @relation(fields: [userGarageId], references: [id], onDelete: Cascade)
  tag           String
  source        String     @default("user") // "auto" | "user"
}
