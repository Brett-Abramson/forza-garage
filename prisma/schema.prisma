generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Neon's pooled endpoint natively supports the session-level commands and
  // prepared statements Prisma's migration engine needs, so a single pooled
  // URL serves both runtime queries and `prisma migrate` — no separate
  // directUrl required. (Add ?pgbouncer=true&connection_limit=1 for serverless.)
  url       = env("DATABASE_URL")
}

model Car {
  id          Int           @id @default(autoincrement())
  make        String
  model       String
  year        Int
  division    String
  piClass     String
  piRating    Int
  country     String
  source      String
  sourceInfo  String?
  // Fields not in CSV yet — filled in later
  drivetrain  String?
  engineType  String?
  engineCC    Int?
  cylinders   Int?
  bodyStyle   String?

  // Page 1 — bar stats (0–10 scale, sourced from in-game stat screen)
  statSpeed        Float?
  statHandling     Float?
  statAcceleration Float?
  statLaunch       Float?
  statBraking      Float?
  statOffroad      Float?

  // Page 2 — raw specs
  powerHp       Int?
  torqueFtLb    Int?
  weightLb      Int?
  frontWeight   Int?    // weight distribution % — e.g. 40 means 40/60 F/R
  displacementL Float?

  // Simulation results (from forza.labsgg.com/cars/{slug})
  simZeroToSixty      Float?   // seconds  — 0-60 MPH
  simZeroToHundred    Float?   // seconds  — 0-100 MPH
  simBraking60        Float?   // feet     — 60-0 braking distance
  simBraking100       Float?   // feet     — 100-0 braking distance
  simLateralG60       Float?   // G-force  — lateral grip at 60 mph
  simLateralG120      Float?   // G-force  — lateral grip at 120 mph
  simTopSpeed         Float?   // mph      — simulated top speed
  simAeroEfficiency   Float?   // ratio    — drag/downforce balance
  simMechBalance      Float?   // ratio    — mechanical grip balance F/R
  simAeroBalance      Float?   // ratio    — aerodynamic balance F/R

  // Identity
  value   Int?     // purchase price in credits
  rarity  String?  // Common | Rare | Legendary | Forza Edition

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  garage       UserGarage[]
  metaEntries  CarMeta[]

  @@unique([year, make, model])
  @@index([make])
  @@index([division])
  @@index([piClass])
}

model UserGarage {
  id        Int      @id @default(autoincrement())
  userId    String
  carId     Int
  car       Car      @relation(fields: [carId], references: [id])
  addedAt   DateTime @default(now())
  notes     String?
  pinned    Boolean  @default(false)
  tags      CarTag[]

  // Per-user stat overrides — null means "use the shared Car value"
  statSpeedOverride        Float?
  statHandlingOverride     Float?
  statAccelerationOverride Float?
  statLaunchOverride       Float?
  statBrakingOverride      Float?
  statOffroadOverride      Float?
  powerHpOverride          Int?
  torqueFtLbOverride       Int?
  weightLbOverride         Int?
  frontWeightOverride      Int?
  displacementLOverride    Float?
  rarityOverride           String?

  @@index([userId])
  @@unique([userId, carId])
}

model CarMeta {
  id         Int       @id @default(autoincrement())
  carId      Int
  car        Car       @relation(fields: [carId], references: [id], onDelete: Cascade)
  piClass    String
  raceType   String
  rank       Int?
  label      String
  notes      String?
  source     String
  active     Boolean   @default(true)
  recordedAt DateTime  @default(now())
  replacedAt DateTime?

  @@index([carId])
  @@index([piClass])
  @@index([raceType])
  @@index([recordedAt])
  @@index([active, piClass, raceType])
}

model CarTag {
  id            Int        @id @default(autoincrement())
  userGarageId  Int
  userGarage    UserGarage @relation(fields: [userGarageId], references: [id], onDelete: Cascade)
  tag           String
  source        String     @default("user") // "auto" | "user"

  // Every tag read (include) and tag edit (deleteMany) filters on this FK.
  @@index([userGarageId])
}

model UserPreferences {
  id          Int      @id @default(autoincrement())
  userId      String   @unique                // Clerk user ID
  units       String   @default("English")   // "English" | "Metric"
  powerUnits  String   @default("hp")        // "hp" | "PS" | "kW"
  springUnits String   @default("N/mm")      // "N/mm" | "lb/in" | "kgf/mm"
  updatedAt   DateTime @updatedAt
}

model Track {
  id           Int      @id @default(autoincrement())
  raceName     String                    // e.g. "Cedar Run Street Race" — scrape identity key
  raceType     String                    // "Street Race" | "Road Race" | "Touge Race" | "Drag Race"
                                          // | "Dirt Race" | "Cross Country" | "Wristband Event"
  distanceMi   Float?                    // null when the source page doesn't list one (e.g. Hakone Nanamagari)
  laps         Int?
  region       String?                   // "Discover Japan" | "Horizon Festival" — free string, not enum
                                          // (forward-compatible with DLC regions without a migration,
                                          // same reasoning as Car.source)

  // Reference images — URLs only, never re-hosted binaries. See scrape_tracks.js
  // header comment: these are game/ForzaLabs assets, linked by reference.
  trackImageUrl   String?
  detailsImageUrl String?

  sourceUrl    String                    // provenance — where this row was scraped from
  scrapedAt    DateTime  @default(now())

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  profile      TrackProfile?             // 1:1 — the current derived summary, if one exists
  corners      TrackCorner[]             // 1:many — ordered corner breakdown

  @@unique([raceName])
  @@index([raceType])
  @@index([region])
}

// One active telemetry-derived summary per Track. Distinct from Track itself
// because this data has a fundamentally different source and lifecycle —
// scraped fields are refreshed by re-running the scraper; profile fields are
// only ever produced by the telemetry-ingest pipeline (your own captured
// laps, later community-submitted laps), and may not exist yet for most
// tracks. Nullable fields here are the norm, not the exception, especially
// early on.
model TrackProfile {
  id              Int      @id @default(autoincrement())
  trackId         Int      @unique
  track           Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)

  elevationDeltaFt   Float?     // max(y) - min(y) across the reference lap(s)
  elevationMinFt     Float?
  elevationMaxFt     Float?

  avgLateralG        Float?     // aggregate across all detected corners
  maxLateralG        Float?
  brakeZoneCount     Int?       // count of distinct braking events on a clean lap
  cornerCount        Int?       // detected corners — cross-check against the site's own turn count, if known

  // Provenance / confidence — how much to trust this profile. A profile
  // built from 1 unfiltered solo lap should read differently in the UI than
  // one averaged over several quality-checked community laps.
  sampleLapCount     Int      @default(1)
  source             String              // "solo-capture" | "community-bundle" | ...
  qualityChecked     Boolean  @default(false)  // passed the clean-lap slip/spin/contact checks
  notes              String?             // free text, e.g. "raced in traffic, treat speed data as noisy"

  capturedAt         DateTime?           // when the underlying lap(s) were driven, not when this row was written
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

// Per-corner breakdown, ordered by position along the lap. Populated by the
// same telemetry-ingest pipeline as TrackProfile — a corner list is
// structurally a table, not a scalar column, hence the separate model
// rather than cramming it onto Track or TrackProfile as JSON.
model TrackCorner {
  id              Int      @id @default(autoincrement())
  trackId         Int
  track           Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)

  sequence        Int                  // 1-based order along the lap — this is the sort key
  label           String?              // optional human label, e.g. "Turn 4" or a community nickname

  distanceIntoLapFt Float?             // where this corner starts, for placing it on an elevation/speed chart
  minSpeedMph       Float?
  maxLateralG       Float?
  brakingZone       Boolean  @default(false)
  throttleOnExit    Boolean?           // null = not determined; true/false once derived from telemetry

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([trackId, sequence])
  @@index([trackId])
}
